{
  "name": "@sharingbox/http-methods",
  "version": "1.0.0",
  "description": "HTTP (JavaScript) methods to communicate with the eventManager by sharingbox servers",
  "main": "src/index.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "clean": "rimraf ./dist && mkdir dist",
    "test:print": "mocha -r ts-node/register test/print.test.ts",
    "test:stream": "mocha -r ts-node/register test/stream-livefeed.test.ts",
    "test": "mocha -r ts-node/register test/*.test.ts",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "webpack": "node webpack/build.js"
  },
  "babel": {
    "presets": [
      "@babel/preset-env"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicolasmondain/http-methods.git"
  },
  "author": "nicolasmondain",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nicolasmondain/http-methods/issues"
  },
  "homepage": "https://github.com/nicolasmondain/http-methods#readme",
  "devDependencies": {
    "@babel/core": "7.16.0",
    "@babel/node": "7.16.0",
    "@babel/preset-env": "7.16.0",
    "@types/chai": "4.2.22",
    "@types/chai-as-promised": "7.1.4",
    "@types/mocha": "9.0.0",
    "@types/node": "16.11.7",
    "@types/qs": "6.9.7",
    "@typescript-eslint/eslint-plugin": "5.3.1",
    "@typescript-eslint/parser": "5.3.1",
    "babel-loader": "8.2.3",
    "chai": "4.3.4",
    "chai-as-promised": "7.1.1",
    "eslint": "8.2.0",
    "mocha": "9.1.3",
    "npm-run-all": "4.1.5",
    "ts-loader": "9.2.6",
    "ts-node": "10.4.0",
    "typescript": "4.4.4",
    "webpack": "5.62.1",
    "webpack-cli": "4.9.1",
    "webpack-dev-server": "4.4.0",
    "webpack-merge": "5.8.0",
    "webpack-node-externals": "3.0.0"
  },
  "dependencies": {
    "@sharingbox/http-status": "1.0.2",
    "axios": "0.24.0",
    "qs": "6.10.1"
  }
